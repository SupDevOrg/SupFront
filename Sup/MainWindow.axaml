<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Sup.MainWindow"
        Title="Sup"
        MinWidth="1200"
        MinHeight="800">
  <Grid>
    <Grid Background="{StaticResource AppBackgroundBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Column="0"
              Margin="48,48,24,48"
              Background="{StaticResource SurfaceAltBrush}"
              CornerRadius="{StaticResource CardCornerRadius}">
        <Grid>
          <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#442560F5" Offset="0"/>
              <GradientStop Color="#331E3A8A" Offset="0.6"/>
              <GradientStop Color="#220F172A" Offset="1"/>
            </LinearGradientBrush>
          </Grid.Background>
          <StackPanel Margin="48" Spacing="24">
            <TextBlock Text="Sup" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
            <StackPanel Spacing="12">
              <TextBlock Text="Добро пожаловать!" Classes="display" Foreground="White"/>
              <TextBlock Text="Вставьте текст приветсвия."
                         Foreground="#FFE0E7FF" FontSize="16"/>
            </StackPanel>
            <Border Background="#208491F5" CornerRadius="12" Padding="24" Effect="{StaticResource SoftShadowEffect}">
              <StackPanel Spacing="12">
                <TextBlock Text="Вставьте текст" FontWeight="SemiBold" Foreground="White" FontSize="18"/>
                <TextBlock Text="Вставьте текст, но больше."
                           Foreground="#FFCBD5F5" FontSize="14"/>
              </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceOverlayBrush}" Padding="16" CornerRadius="12">
            <TextBlock Text="Входя, вы принимаете (правила конфеденциальности и еще какая-нибудь муть)."
                       Classes="muted" FontSize="13"/>
            </Border>
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Margin="24,48,48,48"
              Background="{StaticResource SurfaceBrush}"
              CornerRadius="{StaticResource CardCornerRadius}"
              Padding="{StaticResource CardPadding}"
              Effect="{StaticResource SoftShadowEffect}">
        <StackPanel Spacing="24" Width="360">
          <!-- Заголовок с переключением между входом и регистрацией -->
          <StackPanel Spacing="8">
            <TextBlock x:Name="TitleText" Text="Вход в Sup" Classes="title"/>
            <TextBlock x:Name="SubtitleText" Text="Введите данные аккаунта, чтобы продолжить" Classes="subtle"/>
          </StackPanel>

          <!-- Основные поля для входа и регистрации -->
          <StackPanel x:Name="MainFields" Spacing="16">
            <StackPanel Spacing="6">
              <TextBlock Text="Логин" Classes="caption"/>
              <TextBox x:Name="LoginTextBox" Watermark="Введите логин"/>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="Пароль" Classes="caption"/>
              <TextBox x:Name="PasswordTextBox" Watermark="Введите пароль" PasswordChar="*"/>
            </StackPanel>
            
            <!-- Поле для email (только в режиме регистрации) -->
            <StackPanel x:Name="EmailField" Spacing="6" IsVisible="False">
              <TextBlock Text="Email (опционально)" Classes="caption"/>
              <TextBox x:Name="EmailTextBox" Watermark="Введите email"/>
              <TextBlock Text="Можно оставить пустым" Classes="muted" FontSize="11"/>
            </StackPanel>
          </StackPanel>

          <!-- Панель для подтверждения email -->
          <StackPanel x:Name="EmailVerificationPanel" Spacing="16" IsVisible="False">
            <StackPanel Spacing="6">
              <TextBlock Text="Код подтверждения" Classes="caption"/>
              <TextBox x:Name="VerificationCodeTextBox" Watermark="Введите код из email"/>
            </StackPanel>
            <TextBlock Text="На ваш email был отправлен код подтверждения" 
                       Classes="muted" FontSize="13" TextWrapping="Wrap"/>
          </StackPanel>

          <!-- Кнопки для входа -->
          <StackPanel x:Name="LoginButtons" Spacing="12">
            <Button x:Name="LoginButton" Content="Войти" HorizontalAlignment="Stretch"/>
            <Button x:Name="SwitchToRegisterButton" Content="Создать аккаунт" Classes="outlined" HorizontalAlignment="Stretch"/>
          </StackPanel>

          <!-- Кнопки для регистрации -->
          <StackPanel x:Name="RegisterButtons" Spacing="12" IsVisible="False">
            <Button x:Name="RegisterButton" Content="Зарегистрироваться" HorizontalAlignment="Stretch"/>
            <Button x:Name="SwitchToLoginButton" Content="Назад ко входу" Classes="outlined" HorizontalAlignment="Stretch"/>
          </StackPanel>

          <!-- Кнопки для подтверждения email -->
          <StackPanel x:Name="VerifyButtons" Spacing="12" IsVisible="False">
            <Button x:Name="VerifyEmailButton" Content="Подтвердить email" HorizontalAlignment="Stretch"/>
            <Button x:Name="ResendCodeButton" Content="Отправить код повторно" Classes="outlined" HorizontalAlignment="Stretch"/>
          </StackPanel>

          <TextBlock x:Name="StatusMessage"
                     HorizontalAlignment="Center"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource SecondaryBrush}"
                     FontSize="15"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     Opacity="1"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>