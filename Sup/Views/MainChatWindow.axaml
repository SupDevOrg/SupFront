<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sup"
        xmlns:models="clr-namespace:Sup.Models"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="720"
        x:Class="Sup.Views.MainChatWindow"
        Title="Sup"
        MinWidth="1180"
        MinHeight="700">

  <Window.Resources>
    <local:HorizontalAlignmentConverter x:Key="HorizontalAlignmentConverter"/>
    <local:MessageBackgroundConverter x:Key="MessageBackgroundConverter"/>
    <local:MessageTextColorConverter x:Key="MessageTextColorConverter"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.caption">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style Selector="Button">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    </Style>

    <Style Selector="Button.outlined">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
  </Window.Styles>

  <Grid Background="{StaticResource AppBackgroundBrush}">
      <Grid ColumnDefinitions="1*,3*">
        <Border Grid.Column="0"
                Margin="0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="0"
                Padding="28">
          <Grid RowDefinitions="Auto,*,Auto">
            <Border x:Name="LeftSearchPanel"
                    Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="20"
                    Margin="0,0,0,40">
              <StackPanel Spacing="16">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button x:Name="SearchTabButton"
                          Content="Поиск"
                          Classes="outlined"
                          Grid.Column="0"
                          HorizontalAlignment="Stretch"/>
                  <Button x:Name="FriendsTabButton"
                          Content="Друзья"
                          Classes="outlined"
                          Grid.Column="1"
                          HorizontalAlignment="Stretch"/>
                </Grid>
                <StackPanel Spacing="4">
                  <TextBlock Text="Диалоги" Classes="title"/>
                </StackPanel>
                <Button x:Name="CreateGroupButton"
                        Content="Создать группу"
                        Classes="outlined"
                        HorizontalAlignment="Stretch"/>

                <TextBox x:Name="DialogsSearchTextBox" Watermark="Поиск среди ваших диалогов..."/>
              </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="12,12,12,20"
                    Margin="0,20,0,24">
              <ListBox x:Name="UsersListBox"
                       MinHeight="320"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerTheme>
                  <ControlTheme TargetType="ListBoxItem">
                    <Setter Property="Template">
                      <ControlTemplate>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Margin="0,2,0,2"/>
                      </ControlTemplate>
                    </Setter>
                  </ControlTheme>
                </ListBox.ItemContainerTheme>
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:ChatListItem">
                    <Border Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="White"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,2"
                            Cursor="Hand">
                      <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding DisplayName}"
                                     FontWeight="SemiBold"
                                     FontSize="16"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                          <Border Grid.Column="1"
                                  Background="{StaticResource SurfaceBrush}"
                                  CornerRadius="999"
                                  Padding="8,2"
                                  IsVisible="{Binding IsGroup}">
                            <TextBlock Text="GROUP"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                          </Border>
                        </Grid>
                        <TextBlock Text="{Binding LastMessage}"
                                   TextWrapping="Wrap"
                                   Opacity="0.8"
                                   MaxHeight="40"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding LastMessageTime}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   HorizontalAlignment="Right"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="20">
              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center" ColumnSpacing="12">
                <Border Grid.Column="0" Width="48" Height="48" Background="Black" CornerRadius="8" ClipToBounds="True">
                  <Image x:Name="UserAvatarImage" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <TextBlock x:Name="UserNameLabel" Text="user" FontSize="18" FontWeight="SemiBold"/>
                  <TextBlock Text="В сети" Classes="muted"/>
                </StackPanel>

                <Button Grid.Column="2" x:Name="SettingsButton" Content="⚙" HorizontalAlignment="Right" Width="32" Height="32" Padding="0" FontSize="18" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}"/>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="0"
                Padding="32">
          <Grid>
            <Grid x:Name="MainPanels" RowDefinitions="Auto,*,Auto">
              <Grid x:Name="ChatPanel" RowDefinitions="Auto,Auto,*,Auto" Grid.Row="0" Grid.RowSpan="3">
                <Border x:Name="ActiveCallBar"
                        Grid.Row="0"
                        IsVisible="False"
                        Background="#1A4A90E2"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="12,8"
                        Margin="0,0,0,8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock x:Name="CallStatusText"
                               Text="Звонок..."
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Button x:Name="EndCallButton"
                            Grid.Column="1"
                            Content="Завершить"
                            Classes="outlined"
                            Padding="8,4"
                            FontSize="13"
                            Height="32"/>
                  </Grid>
                </Border>
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" Margin="0,0,0,20" VerticalAlignment="Center">
                  <Border Grid.Column="0"
                          Width="44" Height="44"
                          Background="{StaticResource SurfaceAltBrush}"
                          CornerRadius="8"
                          ClipToBounds="True">
                    <Grid>
                      <Image x:Name="ChatUserAvatarImage" Stretch="UniformToFill"/>
                      <TextBlock x:Name="ChatUserAvatarPlaceholder"
                                 Text="GR"
                                 IsVisible="False"
                                 FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                  </Border>

                  <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                    <TextBlock x:Name="ChatUserName" Text="Имя пользователя" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ChatSubtitleText"
                               Text="История ваших сообщений"
                               Classes="muted"/>
                  </StackPanel>

                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="ManageGroupButton"
                            Content="Участники"
                            Classes="outlined"
                            IsVisible="False"
                            Padding="12,6"
                            Height="36"/>
                    <Button x:Name="CallButton"
                            Content="📞"
                            Width="42"
                            Height="42"
                            Padding="0"
                            FontSize="20"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="Позвонить"
                            Foreground="{StaticResource TextSecondaryBrush}"/>
                  </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Padding="12"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="{StaticResource ControlCornerRadius}">
                  <ScrollViewer Name="MessagesScrollViewer"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled">
                    <ListBox x:Name="MessagesListBox"
                             BorderThickness="0"
                             Background="Transparent">
                      <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="ListBoxItem">
                          <Setter Property="Template">
                            <ControlTemplate>
                              <ContentPresenter Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                Margin="0,2,0,2"/>
                            </ControlTemplate>
                          </Setter>
                        </ControlTheme>
                      </ListBox.ItemContainerTheme>
                      <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:MessageListItem">
                          <Border HorizontalAlignment="{Binding IsOwnMessage, Converter={StaticResource HorizontalAlignmentConverter}}"
                                  CornerRadius="12"
                                  Padding="12"
                                  Margin="0,4,0,4"
                                  Background="{Binding IsOwnMessage, Converter={StaticResource MessageBackgroundConverter}}"
                                  MaxWidth="400">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding SenderName}"
                                         FontWeight="SemiBold"
                                         FontSize="12"
                                         Foreground="{Binding IsOwnMessage, Converter={StaticResource MessageTextColorConverter}}"/>
                              <TextBlock Text="{Binding Content}"
                                         TextWrapping="Wrap"
                                         FontSize="14"
                                         Foreground="{Binding IsOwnMessage, Converter={StaticResource MessageTextColorConverter}}"/>
                              <TextBlock Text="{Binding Time}"
                                         FontSize="10"
                                         Opacity="0.6"
                                         HorizontalAlignment="Right"
                                         Foreground="{Binding IsOwnMessage, Converter={StaticResource MessageTextColorConverter}}"/>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </ScrollViewer>
                </Border>

                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,20,0,0">
                  <TextBox Grid.Column="0"
                           x:Name="MessageTextBox"
                           Watermark="Введите сообщение..." 
                           VerticalAlignment="Center"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           MinHeight="40"/>
                  <Button Grid.Column="1"
                          x:Name="SendMessageButton"
                          Content="Отправить" 
                          MinWidth="100"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          Height="40"/>
                </Grid>
              </Grid>

              <Grid x:Name="GlobalSearchPanel" RowDefinitions="Auto,Auto,*,Auto" Grid.Row="0" Grid.RowSpan="3" IsVisible="False">
                <StackPanel Orientation="Horizontal" Spacing="12" Grid.Row="0" Margin="0,0,0,16">
                  <TextBlock Text="Глобальный поиск" Classes="title" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBox x:Name="SearchGlobalTextBox" Watermark="Введите имя для поиска" Grid.Row="1" Margin="0,0,0,16"/>

                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="12"
                        Margin="0,0,0,16">
                  <ListBox x:Name="GlobalUsersListBox"
                           ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerTheme>
                      <ControlTheme TargetType="ListBoxItem">
                        <Setter Property="Template">
                          <ControlTemplate>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Margin="0,2,0,2"/>
                          </ControlTemplate>
                        </Setter>
                      </ControlTheme>
                    </ListBox.ItemContainerTheme>
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="models:SearchResultItemDto">
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,2"
                                Cursor="Hand">
                          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                            <Border Grid.Column="0" Width="40" Height="40" Background="Black" CornerRadius="6" ClipToBounds="True">
                              <Image Stretch="UniformToFill" Source="{Binding AvatarBitmap}"/>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Username}"
                                       FontSize="16"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                              <Button Content="Добавить в друзья"
                                      Classes="elevated"
                                      Padding="8,4"
                                      FontSize="12"
                                      MinWidth="140"
                                      Tag="{Binding Id}"
                                      IsVisible="{Binding CanAddFriend}"/>
                              <Button Content="Принять"
                                      Classes="elevated"
                                      Padding="8,4"
                                      FontSize="12"
                                      MinWidth="140"
                                      Tag="{Binding Id}"
                                      IsVisible="{Binding HasIncomingRequest}"/>
                              <Button Content="Отклонить"
                                      Classes="outlined"
                                      Padding="8,4"
                                      FontSize="12"
                                      MinWidth="140"
                                      Tag="{Binding Id}"
                                      IsVisible="{Binding HasIncomingRequest}"/>
                              <Button Content="Отменить запрос"
                                      Classes="outlined"
                                      Padding="8,4"
                                      FontSize="12"
                                      MinWidth="140"
                                      Tag="{Binding Id}"
                                      IsVisible="{Binding HasOutgoingRequest}"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <Border Grid.Row="3"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="16,12">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                    <Button x:Name="PrevPageButton" Content="← Назад" Classes="outlined" IsEnabled="False" MinWidth="140"/>
                    <TextBlock x:Name="PageInfoText" Text="Страница 1 из 1" VerticalAlignment="Center"/>
                    <Button x:Name="NextPageButton" Content="Вперед →" IsEnabled="False" MinWidth="140"/>
                  </StackPanel>
                </Border>
              </Grid>

              <Grid x:Name="FriendsPanel" RowDefinitions="Auto,*,Auto" Grid.Row="0" Grid.RowSpan="3" IsVisible="False">
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <TextBlock Text="Друзья и запросы" Classes="title" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button x:Name="FriendsTabButton2" Content="Друзья" Classes="outlined" Grid.Column="0" HorizontalAlignment="Stretch"/>
                        <Button x:Name="RequestsTabButton" Content="Запросы" Classes="outlined" Grid.Column="1" HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="1"
                        x:Name="FriendsTabContent"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="20"
                        Margin="0,0,0,16"
                        IsVisible="True">
                    <ListBox x:Name="FriendsListBox"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:FriendListItemDto">
                                <Border Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,6"
                                        Cursor="Hand"
                                        x:Name="FriendBorder"
                                        Height="80">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="RemoveFriendMenuItem"
                                                      Header="Удалить из друзей" 
                                                      Foreground="#D84040"
                                                      Tag="{Binding Id}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalAlignment="Center">
                                        <!-- Avatar -->
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Background="Black"
                                                CornerRadius="6"
                                                ClipToBounds="True">
                                            <Image Stretch="UniformToFill" Source="{Binding AvatarBitmap}"/>
                                        </Border>
                                        <!-- Username -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Username}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="1"
                        x:Name="RequestsTabContent"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="20"
                        Margin="0,0,0,16"
                        IsVisible="False">
                    <Grid ColumnDefinitions="*,Auto,*">
                        <Grid Grid.Column="0" RowDefinitions="Auto,*">
                            <TextBlock Text="Входящие запросы" Classes="caption" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1"
                                     x:Name="IncomingRequestsListBox"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:FriendListItemDto">
                                        <Border Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,6"
                                                Height="80">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                                <!-- Avatar -->
                                                <Border Grid.Column="0"
                                                        Width="48"
                                                        Height="48"
                                                        Background="Black"
                                                        CornerRadius="6"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Center">
                                                    <Image Stretch="UniformToFill" Source="{Binding AvatarBitmap}"/>
                                                </Border>
                                                <!-- Username -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Username}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <!-- Buttons -->
                                                <Button Grid.Column="2"
                                                        x:Name="AcceptIncomingButton"
                                                        Content="Принять"
                                                        Classes="elevated"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Tag="{Binding Id}"/>
                                                <Button Grid.Column="3"
                                                        x:Name="RejectIncomingButton"
                                                        Content="Отклонить"
                                                        Classes="outlined"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Tag="{Binding Id}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Border Grid.Column="1"
                                Width="1"
                                Background="{StaticResource TextSecondaryBrush}"
                                Opacity="0.3"
                                Margin="20,0"/>

                        <Grid Grid.Column="2" RowDefinitions="Auto,*">
                            <TextBlock Text="Исходящие запросы" Classes="caption" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1"
                                     x:Name="OutgoingRequestsListBox"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:FriendListItemDto">
                                        <Border Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,6"
                                                Height="80">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <!-- Avatar -->
                                                <Border Grid.Column="0"
                                                        Width="48"
                                                        Height="48"
                                                        Background="Black"
                                                        CornerRadius="6"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Center">
                                                    <Image Stretch="UniformToFill" Source="{Binding AvatarBitmap}"/>
                                                </Border>
                                                <!-- Username -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Username}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <!-- Button -->
                                                <Button Grid.Column="2"
                                                        x:Name="CancelOutgoingButton"
                                                        Content="Отменить запрос" 
                                                        Classes="outlined"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Tag="{Binding Id}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
            </Grid>
          </Grid>
        </Border>

        <Border x:Name="SettingsPanel"
                Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="0"
                Padding="28"
                Margin="0"
                IsVisible="False">
          <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Button x:Name="BackFromSettingsButton" Content="Назад" Classes="outlined" Width="120"/>
              <TextBlock Text="Настройки" Classes="title" VerticalAlignment="Center"/>
            </StackPanel>
            <Button x:Name="VoiceSettingsButton" Content="Голосовые нстройки" HorizontalAlignment="Stretch"/>
            <Button x:Name="AvatarSettingsButton" Content="Смена аватарки" HorizontalAlignment="Stretch"/>
            <Button x:Name="LogoutButton"
                    Content="Выйти из аккаунта"
                    Classes="outlined"
                    HorizontalAlignment="Stretch"/>
          </StackPanel>
        </Border>

        <Border x:Name="VoicePanel"
                Grid.Column="1"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="0"
                Padding="32"
                IsVisible="False">
          <StackPanel Spacing="18">
            <TextBlock Text="Аудио" Classes="title"/>

            <StackPanel Spacing="8">
              <TextBlock Text="Микрофон" Classes="caption"/>
              <ComboBox x:Name="MicrophoneComboBox"/>
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Звук" Classes="caption"/>
              <ComboBox x:Name="AudioOutputComboBox"/>
            </StackPanel>

            <Border Padding="20,40" ClipToBounds="False" MinHeight="120">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                <Button x:Name="TestVoiceButton" Content="Проверить голос" Width="200" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Stretch" ClipToBounds="False">
                  <TextBlock Text="Громкость с микрофона°" Classes="caption"/>
                  <Border Margin="0,24,0,24" ClipToBounds="False">
                    <Slider x:Name="VoiceVolumeSlider" IsEnabled="False" Minimum="0" Maximum="100" Value="0" TickFrequency="10"/>
                  </Border>
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </Border>

        <Border x:Name="AvatarPanel"
                Grid.Column="1"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="0"
                Padding="32"
                IsVisible="False">
          <StackPanel Spacing="18">
            <TextBlock Text="Аватарка" Classes="title"/>

            <Border Padding="20,20" ClipToBounds="False">
              <StackPanel Spacing="20" HorizontalAlignment="Center">
                <Border Width="512" Height="512" Background="Black" CornerRadius="8" ClipToBounds="True">
                  <Image x:Name="AvatarImage"
                         Stretch="UniformToFill"/>
                </Border>
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                  <Button x:Name="SelectAvatarButton" Content="Сменить аватарку" Width="300" HorizontalAlignment="Center"/>
                  <TextBlock x:Name="AvatarStatusMessage"
                             Text=""
                             FontSize="14"
                             Foreground="Green"
                             HorizontalAlignment="Center"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </Grid>
      <Border x:Name="CreateGroupOverlay"
              IsVisible="False"
              Background="#CC1F2937">
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="16"
                Padding="24"
                Width="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel Spacing="16">
            <TextBlock Text="Создать группу"
                       Classes="title"/>
            <TextBlock Text="Выберите минимум двух друзей"
                       Classes="muted"/>
            <ListBox x:Name="CreateGroupFriendsListBox"
                     SelectionMode="Multiple"
                     MinHeight="220"
                     MaxHeight="320"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="models:FriendListItemDto">
                  <Border Background="{StaticResource SurfaceAltBrush}"
                          CornerRadius="8"
                          Padding="12"
                          Margin="0,2">
                    <TextBlock Text="{Binding Username}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock x:Name="CreateGroupSelectionText"
                       Text="Выбрано: 0"
                       Classes="muted"/>
            <TextBlock x:Name="CreateGroupStatusText"
                       Text=""
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right">
              <Button x:Name="CloseCreateGroupButton"
                      Content="Отмена"
                      Classes="outlined"/>
              <Button x:Name="ConfirmCreateGroupButton"
                      Content="Создать"
                      IsEnabled="False"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>
      <Border x:Name="GroupMembersOverlay"
              IsVisible="False"
              Background="#CC1F2937">
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="16"
                Padding="24"
                Width="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel Spacing="16">
            <TextBlock Text="Участники группы"
                       Classes="title"/>
            <StackPanel Spacing="8">
              <TextBlock Text="Сейчас в группе"
                         Classes="caption"/>
              <ScrollViewer MaxHeight="180"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CurrentGroupMembersItemsControl">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:ChatParticipantDto">
                      <Border Background="{StaticResource SurfaceAltBrush}"
                              CornerRadius="8"
                              Padding="12"
                              Margin="0,2">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
            <StackPanel Spacing="8">
              <TextBlock Text="Добавить из друзей"
                         Classes="caption"/>
              <ListBox x:Name="AddGroupMembersListBox"
                       SelectionMode="Multiple"
                       MinHeight="140"
                       MaxHeight="220"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:FriendListItemDto">
                    <Border Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,2">
                      <TextBlock Text="{Binding Username}"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
            <TextBlock x:Name="GroupMembersSelectionText"
                       Text="Выбрано для добавления: 0"
                       Classes="muted"/>
            <TextBlock x:Name="GroupMembersStatusText"
                       Text=""
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right">
              <Button x:Name="CloseGroupMembersButton"
                      Content="Закрыть"
                      Classes="outlined"/>
              <Button x:Name="ConfirmAddGroupMembersButton"
                      Content="Добавить"
                      IsEnabled="False"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>

      <Border x:Name="IncomingCallOverlay"
              IsVisible="False"
              Background="#CC1F2937">
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="16"
                Padding="32"
                Width="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel Spacing="20" HorizontalAlignment="Center">
            <TextBlock Text="📞 Входящий звонок"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock x:Name="IncomingCallUserName"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
              <Button x:Name="AcceptCallButton" Content="✔ Принять" Width="140"/>
              <Button x:Name="RejectCallButton" Content="✖ Отклонить" Classes="outlined" Width="140"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>

      <!-- Новое всплывающее уведомление -->
      <Border x:Name="NotificationPopup" IsVisible="False" 
              HorizontalAlignment="Right" VerticalAlignment="Top" 
              Background="#333333" CornerRadius="8" Padding="12" 
              Margin="0,10,10,0" Opacity="0.9">
          <StackPanel>
              <TextBlock x:Name="NotificationTitle" 
                         Foreground="White" FontWeight="Bold" Text="Уведомление" />
              <TextBlock x:Name="NotificationMessage" 
                         Foreground="#DDDDDD" TextWrapping="Wrap" MaxWidth="250" />
          </StackPanel>
      </Border>
  </Grid>
</Window>
